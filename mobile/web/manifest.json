{
    "name": "FemControl",
    "short_name": "FemControl",
    "start_url": "/",
    "display": "standalone",
    "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
    "background_color": "#FAF7F4",
    "theme_color": "#D4735E",
    "description": "Tu ciclo, tu bienestar. Seguimiento del ciclo menstrual orientado a la privacidad. Funciona sin internet.",
    "orientation": "portrait-primary",
    "lang": "es",
    "dir": "ltr",
    "categories": ["health", "lifestyle", "medical"],
    "prefer_related_applications": false,
    "scope": "/",
    "id": "/femcontrol",

    "icons": [
        {
            "src": "icons/Icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "icons/Icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "icons/Icon-maskable-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "icons/Icon-maskable-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],

    "shortcuts": [
        {
            "name": "Registrar hoy",
            "short_name": "Registrar",
            "description": "Registrar cómo me siento hoy",
            "url": "/log",
            "icons": [
                {
                    "src": "icons/Icon-192.png",
                    "sizes": "192x192",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "Mi historial",
            "short_name": "Historial",
            "description": "Ver el historial de ciclos",
            "url": "/history",
            "icons": [
                {
                    "src": "icons/Icon-192.png",
                    "sizes": "192x192",
                    "type": "image/png"
                }
            ]
        }
    ],

    "screenshots": [
        {
            "src": "icons/Icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Pantalla principal de FemControl"
        }
    ]
}

